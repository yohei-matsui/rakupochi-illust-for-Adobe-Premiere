<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.rakupochi.illustsearch" ExtensionBundleVersion="1.0.0" ExtensionBundleName="ラクポチ イラスト">
